# Supabase Configuration
# Get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini AI
# Get from https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Backend API
EXPO_PUBLIC_BACKEND_URL=http://your-backend-host:8080

# Development JWT Token (Option 3 - see backend/DEV_AUTH_GUIDE.md)
# Generate with: go run backend/dev-token.go or use jwt.io
# EXPO_PUBLIC_DEV_JWT_TOKEN=your-dev-jwt-token

# Rembg Service (Background Removal)
# GCP Cloud Run service for background removal
EXPO_PUBLIC_REMBG_SERVICE_URL=https://outfit-extractor-787746538147.us-central1.run.app

# Optional: Fal.ai for virtual try-on (Phase 2)
# EXPO_PUBLIC_FAL_API_KEY=your-fal-api-key
